rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MANDALPULSE SECURITY RULES
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a robust Role-Based Access Control (RBAC) model using "Authorization Independence."
     * Instead of relying on fields within user documents, roles are verified via specific lookup collections
     * (/roles_admins, /roles_editors, /roles_reporters). This ensures high performance and prevents 
     * recursive rules or expensive get() calls.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid));
    }

    function isEditor() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_editors/$(request.auth.uid));
    }

    function isReporter() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_reporters/$(request.auth.uid));
    }

    function isStaff() {
      return isAdmin() || isEditor();
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for user profiles. Users can manage their own profile; admins have full access.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    /**
     * @description Role lookup collections. Read-only for the owner; write for admins.
     */
    match /roles_admins/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list, create, update, delete: if isAdmin();
    }
    match /roles_editors/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list, create, update, delete: if isAdmin();
    }
    match /roles_reporters/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list, create, update, delete: if isAdmin();
    }

    /**
     * @description News posts awaiting moderation. Accessible to authors (reporters) and staff.
     */
    match /pending_news_posts/{newsPostId} {
      allow get: if isSignedIn() && (isOwner(resource.data.authorId) || isStaff());
      allow list: if isStaff();
      allow create: if isReporter() && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn() && (isExistingOwner(resource.data.authorId) || isStaff()) && request.resource.data.authorId == resource.data.authorId;
      allow delete: if isSignedIn() && (isExistingOwner(resource.data.authorId) || isStaff());
    }

    /**
     * @description Publicly visible, approved news posts.
     */
    match /approved_news_posts/{newsPostId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isStaff();

      /**
       * @description Comments on approved news posts.
       */
      match /comments/{commentId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid && request.resource.data.newsPostId == newsPostId;
        allow update: if (isExistingOwner(resource.data.authorId) || isAdmin()) && request.resource.data.authorId == resource.data.authorId;
        allow delete: if isExistingOwner(resource.data.authorId) || isAdmin();
      }
    }

    /**
     * @description Push notifications and alerts.
     */
    match /notifications/{notifId} {
      allow get, list: if isSignedIn();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    /**
     * @description App metadata (e.g., location lists).
     */
    match /metadata/{docId} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }

  }
}