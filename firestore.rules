/**
 * Core Philosophy: This ruleset implements a strict Role-Based Access Control (RBAC) and 
 * User-Ownership model. Access is bifurcated based on the lifecycle of content: 
 * unmoderated/private data (pending posts) vs. moderated/public data (approved posts).
 *
 * Data Structure: 
 * - User profiles are stored at `/users/{userId}`.
 * - Approved content is in `/approved_news_posts/{postId}` (Publicly readable).
 * - Moderation queue is in `/pending_news_posts/{postId}` (Restricted).
 * - Sub-resources like comments are nested under approved posts.
 *
 * Key Security Decisions:
 * - Authorization Independence: We use denormalized fields like `author_id` and `location` 
 *   within documents to perform localized security checks, minimizing costly `get()` calls.
 * - Role Resolution: A helper function `getRole()` is used to fetch user permissions 
 *   directly from the Firestore user document, supporting the "Desk Incharge" and "Admin" roles.
 * - Structural Segregation: By separating pending and approved posts into different 
 *   collections, we prevent accidental leakage of unmoderated content via open queries.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    /** @description Checks if the requester is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user is accessing their own record. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Fetches the role of the current authenticated user. */
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    /** @description Verifies if the user has administrative or editorial privileges. */
    function isStaff() {
      return isSignedIn() && (getRole() == 'admin' || getRole() == 'editor' || getRole() == 'Desk Incharge');
    }

    /** @description Verifies if the user has administrative privileges. */
    function isAdmin() {
      return isSignedIn() && getRole() == 'admin';
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for User Profiles. Users can manage their own data; Admins/Editors can view.
     * @path /users/{userId}
     * @allow Authenticated user (get) if userId matches auth.uid.
     * @deny Unauthenticated user (create).
     * @principle Path-based ownership and Role-Based Access Control.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isStaff();
      allow list: if isStaff();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Rules for Approved News. Publicly readable; only Staff can modify content.
     * @path /approved_news_posts/{postId}
     * @allow Any user (get, list).
     * @deny Regular user (update) attempting to change title or content.
     * @principle Structural segregation of public data.
     */
    match /approved_news_posts/{postId} {
      allow get, list: if true;
      allow create: if isStaff();
      allow update: if isStaff() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'engagement']));
      allow delete: if isAdmin();

      /**
       * @description Comments on approved posts.
       * @path /approved_news_posts/{postId}/comments/{commentId}
       */
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
      }
    }

    /**
     * @description Rules for Pending News. This was the source of the reported error. 
     * Reporters can create their own pending posts. Staff can review all.
     * @path /pending_news_posts/{newsPostId}
     * @allow Reporter (create) if author_id in data matches their UID.
     * @deny Reporter (update) if they try to change the author_id.
     * @principle Validates relational integrity and ownership during moderation.
     */
    match /pending_news_posts/{newsPostId} {
      // Logic grouped by Reads and Writes
      allow get: if isSignedIn() && (resource.data.author_id == request.auth.uid || isStaff());
      allow list: if isStaff();
      
      // Critical for the reported error: Allow authors to write their own pending posts
      // and allow "Desk Incharge" (Staff) to perform moderation updates.
      allow create: if isSignedIn() && request.resource.data.author_id == request.auth.uid;
      
      allow update: if resource != null && (isOwner(resource.data.author_id) || isStaff()) && (request.resource.data.author_id == resource.data.author_id);
      
      allow delete: if resource != null && (isOwner(resource.data.author_id) || isAdmin());
    }

    // Default deny for any unmatched paths
    match /{path=**} {
      allow read, write: if false;
    }
  }
}