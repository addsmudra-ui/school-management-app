rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Is the user the Master Admin?
    // Anchored to the specific email for absolute security.
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@telugunewspulse.com';
    }

    // Helper: Is the user an Editor or the Admin?
    function isStaff() {
      return isAdmin() || (
        request.auth != null && 
        exists(/databases/$(database)/documents/roles_editors/$(request.auth.uid))
      );
    }

    // 1. Branding & App Config
    match /config/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. User Profiles
    match /users/{userId} {
      // Admin can manage all. Users can read/write their own.
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow create, update: if isAdmin() || (
        request.auth != null && 
        request.auth.uid == userId && 
        request.resource.data.role != 'admin'
      );
      allow delete: if isAdmin();
    }

    // 3. News Posts (Approved)
    match /approved_news_posts/{id} {
      allow read: if true;
      allow write: if isStaff();
      
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if isStaff() || (request.auth != null && resource.data.userId == request.auth.uid);
      }
    }

    // 4. News Posts (Pending)
    match /pending_news_posts/{id} {
      allow read: if isStaff() || (request.auth != null && resource.data.author_id == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.author_id == request.auth.uid;
      allow update, delete: if isStaff() || (request.auth != null && resource.data.author_id == request.auth.uid);
    }

    // 5. Advertisements
    match /ads/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 6. Notifications
    match /notifications/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 7. Metadata (Locations, Categories)
    match /metadata/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 8. Internal Role tracking
    match /roles_editors/{id} { allow read, write: if isAdmin(); }
    match /roles_reporters/{id} { allow read, write: if isAdmin(); }

    // Fallback: Default to admin-only
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}