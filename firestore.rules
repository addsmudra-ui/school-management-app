
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Last Updated: 2024-05-20
    
    // Global rule for prototype development
    match /{document=**} {
      allow read, write: if true;
    }

    // Explicitly define collection paths to ensure propagation
    match /users/{userId} {
      allow read, write: if true;
      match /private/{doc=**} {
        allow read, write: if true;
      }
    }
    
    match /approved_news_posts/{postId} {
      allow read, write: if true;
      match /comments/{commentId} {
        allow read, write: if true;
      }
    }
    
    match /pending_news_posts/{postId} {
      allow read, write: if true;
    }
    
    match /notifications/{id} {
      allow read, write: if true;
    }
    
    match /metadata/{id} {
      allow read, write: if true;
    }

    match /config/{id} {
      allow read, write: if true;
    }
    
    match /roles_admins/{id} { allow read, write: if true; }
    match /roles_reporters/{id} { allow read, write: if true; }
    match /roles_editors/{id} { allow read, write: if true; }
  }
}
