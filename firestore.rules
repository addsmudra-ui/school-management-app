rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid));
    }

    function isReporter() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_reporters/$(request.auth.uid));
    }

    function isStaff() {
      return isAdmin() || exists(/databases/$(database)/documents/roles_editors/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    // 1. PUBLIC CONTENT - Anyone can read approved news and notifications
    match /approved_news_posts/{id} {
      allow read: if true;
      allow write: if isStaff();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (resource.data.author_id == request.auth.uid || isStaff());
      }
    }

    match /notifications/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /metadata/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. PENDING CONTENT - Author and Staff only
    match /pending_news_posts/{id} {
      allow read: if isSignedIn() && (resource == null || resource.data.author_id == request.auth.uid || isStaff());
      allow create: if isSignedIn() && (isReporter() || isAdmin());
      allow update, delete: if isSignedIn() && (resource.data.author_id == request.auth.uid || isStaff());
    }

    // 3. USERS & PROFILES
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
      
      match /private/{docId} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }

    // 4. ROLE MARKERS - Critical for security checks
    match /roles_admins/{uid} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin(); 
    }
    match /roles_reporters/{uid} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == uid); 
    }
    match /roles_editors/{uid} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin(); 
    }

    // 5. SYSTEM CONFIG
    match /config/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}