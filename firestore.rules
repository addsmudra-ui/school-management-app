rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * MANDALPULSE SECURITY RULES
     * Deployment Trigger: 2024-05-24T18:30:00Z - Resolved Admin Delete & News List permissions
     */

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid));
    }

    function isReporter() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_reporters/$(request.auth.uid));
    }

    function isStaff() {
      return isAdmin() || exists(/databases/$(database)/documents/roles_editors/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
      
      match /private/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Role markers (Managed by Admins or during registration)
    match /roles_admins/{uid} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin() || (isSignedIn() && !exists(/databases/$(database)/documents/roles_admins/$(uid)) && request.auth.uid == uid); 
    }
    match /roles_editors/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_reporters/{uid} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin() || (isSignedIn() && !exists(/databases/$(database)/documents/roles_reporters/$(uid)) && request.auth.uid == uid); 
    }

    match /approved_news_posts/{newsPostId} {
      // Changed to 'read' to allow both 'get' and 'list'
      allow read: if isSignedIn(); 
      allow create, update, delete: if isStaff();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.author_id == request.auth.uid;
        allow update: if isSignedIn() && resource.data.author_id == request.auth.uid;
        allow delete: if isSignedIn() && (resource.data.author_id == request.auth.uid || isAdmin());
      }
    }

    match /pending_news_posts/{newsPostId} {
      allow read: if isSignedIn() && (resource.data.author_id == request.auth.uid || isStaff());
      allow create: if isReporter() && request.resource.data.author_id == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.author_id == request.auth.uid || isStaff());
    }

    match /notifications/{id} { allow read: if isSignedIn(); allow write: if isStaff(); }
    match /metadata/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /config/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
  }
}