rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MANDALPULSE SECURITY RULES
     *
     * Updated to simplify sign-in checks and ensure robust access for anonymous users.
     * Triggering deployment: 2024-05-20T12:00:00Z
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      // Robust check for any authenticated user (anonymous or provider-based)
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid));
    }

    function isEditor() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_editors/$(request.auth.uid));
    }

    function isReporter() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_reporters/$(request.auth.uid));
    }

    function isStaff() {
      return isAdmin() || isEditor();
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for user profiles.
     * Allows authenticated users to look up profiles (needed for login and display).
     */
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();

      // Nested private data (e.g., likes)
      match /private/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    /**
     * @description Role lookup collections. Read-only for the owner; write for admins.
     */
    match /roles_admins/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list, create, update, delete: if isAdmin();
    }
    match /roles_editors/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list, create, update, delete: if isAdmin();
    }
    match /roles_reporters/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list, create, update, delete: if isAdmin();
    }

    /**
     * @description News posts awaiting moderation.
     */
    match /pending_news_posts/{newsPostId} {
      allow get: if isSignedIn() && (isOwner(resource.data.authorId) || isStaff());
      allow list: if isStaff();
      allow create: if isReporter() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn() && (isExistingOwner(resource.data.authorId) || isStaff());
    }

    /**
     * @description Publicly visible, approved news posts.
     */
    match /approved_news_posts/{newsPostId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isStaff();

      /**
       * @description Comments on approved news posts.
       */
      match /comments/{commentId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if (isExistingOwner(resource.data.authorId) || isAdmin());
      }
    }

    /**
     * @description Push notifications and alerts.
     */
    match /notifications/{notifId} {
      allow get, list: if isSignedIn();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    /**
     * @description App metadata (e.g., location lists).
     */
    match /metadata/{docId} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }

  }
}