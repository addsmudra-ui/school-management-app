rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * MANDALPULSE SECURITY RULES
     * Deployment Trigger: 2024-05-24T12:00:00Z - Fixed Admin permissions for user management
     */

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid));
    }

    function isReporter() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_reporters/$(request.auth.uid));
    }

    function isStaff() {
      return isAdmin() || exists(/databases/$(database)/documents/roles_editors/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    // Publicly readable news for all signed-in users (including anonymous)
    match /approved_news_posts/{newsPostId} {
      allow read: if isSignedIn(); 
      allow create, update, delete: if isStaff();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.author_id == request.auth.uid;
        allow update: if isSignedIn() && resource.data.author_id == request.auth.uid;
        allow delete: if isSignedIn() && (resource.data.author_id == request.auth.uid || isAdmin());
      }
    }

    // Reporter drafts and moderation queue
    match /pending_news_posts/{newsPostId} {
      allow read: if isSignedIn() && (resource == null || resource.data.author_id == request.auth.uid || isStaff());
      allow create: if isReporter() && request.resource.data.author_id == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.author_id == request.auth.uid || isStaff());
    }

    // User profiles and role lookups
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      // Allow creation if it's the user themselves OR an admin
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Allow updates if it's the user themselves OR an admin
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Explicitly allow admins to delete users
      allow delete: if isAdmin();
      
      match /private/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /roles_admins/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_editors/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_reporters/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // System notifications and metadata
    match /notifications/{id} { allow read: if isSignedIn(); allow write: if isStaff(); }
    match /metadata/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /config/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
  }
}