rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MANDALPULSE SECURITY RULES
     *
     * Updated to ensure login flow and profile creation are robust.
     * Triggering deployment: 2024-05-20T15:00:00Z
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid));
    }

    function isEditor() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_editors/$(request.auth.uid));
    }

    function isReporter() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_reporters/$(request.auth.uid));
    }

    function isStaff() {
      return isAdmin() || isEditor();
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      // Allow any signed-in user to check if a phone exists or get a profile
      allow get, list: if isSignedIn();
      // Allow profile creation if the user is authenticated and matching the ID
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Allow updates by owner or admin
      allow update: if (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();

      match /private/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /roles_admins/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list, create, update, delete: if isAdmin();
    }
    match /roles_editors/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list, create, update, delete: if isAdmin();
    }
    match /roles_reporters/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list, create, update, delete: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /pending_news_posts/{newsPostId} {
      allow get: if isSignedIn() && (resource == null || isOwner(resource.data.author_id) || isStaff());
      allow list: if isStaff() || (isSignedIn() && request.query.limit <= 50); 
      allow create: if isReporter() && request.resource.data.author_id == request.auth.uid;
      allow update, delete: if isSignedIn() && (isOwner(resource.data.author_id) || isStaff());
    }

    match /approved_news_posts/{newsPostId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isStaff();

      match /comments/{commentId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.author_id == request.auth.uid;
        allow update, delete: if (isSignedIn() && (resource.data.author_id == request.auth.uid || isAdmin()));
      }
    }

    match /notifications/{notifId} {
      allow get, list: if isSignedIn();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /metadata/{docId} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }

  }
}
