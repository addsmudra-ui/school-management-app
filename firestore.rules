rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Master Admin check based on specific email
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'admin@telugunewspulse.com';
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isEditor() {
      return isSignedIn() && (getUserData().role == 'editor' || isAdmin());
    }

    function isStaff() {
      return isSignedIn() && (getUserData().role in ['admin', 'editor', 'Desk Incharge'] || isAdmin());
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      // Users can only be created as non-admins unless it's the master email
      allow create: if isSignedIn() && (request.resource.data.role != 'admin' || request.auth.token.email == 'admin@telugunewspulse.com');
      
      // Only master admin can change roles or delete users
      allow get: if isOwner(userId) || isStaff();
      allow list: if isStaff();
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();

      match /private/likes {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /approved_news_posts/{postId} {
      allow read: if true; 
      allow create: if isStaff();
      allow update: if isStaff() || 
                   (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'commentsCount']));
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (isOwner(resource.data.authorId) || isAdmin());
      }
    }

    match /pending_news_posts/{newsPostId} {
      allow get: if isSignedIn() && (resource.data.author_id == request.auth.uid || isStaff());
      allow list: if isStaff();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.author_id == request.auth.uid || isStaff());
      allow delete: if isSignedIn() && (resource.data.author_id == request.auth.uid || isAdmin());
    }

    match /notifications/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /ads/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /config/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /metadata/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /roles_admins/{uid} { allow read, write: if isAdmin(); }
    match /roles_editors/{uid} { allow read, write: if isAdmin(); }
    match /roles_reporters/{uid} { allow read, write: if isStaff(); }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}