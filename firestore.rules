rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Master Admin check based on specific email - HIGH PRIORITY
    // This is the SOLE source of truth for admin powers.
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'admin@telugunewspulse.com';
    }

    // Staff check: Master Admin OR authorized role in Firestore
    function isStaff() {
      return isAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor'
      );
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      // Prevent anyone from creating or assuming an 'admin' role in the DB.
      allow create: if isSignedIn() && request.resource.data.role != 'admin';
      allow get: if request.auth.uid == userId || isAdmin() || isStaff();
      allow list: if isAdmin() || isStaff();
      // Owners can update themselves but cannot change their role to admin.
      allow update: if (request.auth.uid == userId && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();

      match /private/likes {
        allow read, write: if request.auth.uid == userId || isAdmin();
      }
    }

    match /approved_news_posts/{postId} {
      allow read: if true; 
      allow create: if isAdmin() || isStaff();
      allow update: if isAdmin() || isStaff() || 
                   (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'commentsCount']));
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || isAdmin());
      }
    }

    match /pending_news_posts/{newsPostId} {
      allow get: if isAdmin() || isStaff() || (isSignedIn() && resource.data.author_id == request.auth.uid);
      allow list: if isAdmin() || isStaff();
      allow create: if isSignedIn();
      allow update: if isAdmin() || isStaff() || (isSignedIn() && resource.data.author_id == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.author_id == request.auth.uid);
    }

    match /notifications/{id} {
      allow read: if true;
      allow write: if isAdmin() || isStaff();
    }

    match /ads/{id} {
      allow read: if true;
      allow write: if isAdmin() || isStaff();
    }

    match /config/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /metadata/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Role tracking collections
    match /roles_editors/{uid} { allow read, write: if isAdmin(); }
    match /roles_reporters/{uid} { allow read, write: if isAdmin() || isStaff(); }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}