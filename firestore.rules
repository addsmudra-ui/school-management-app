rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MANDALPULSE SECURITY RULES
     *
     * Ensures robust login lookup and role-based access.
     * Deployment Trigger: 2024-05-21T11:00:00Z
     */

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checking roles via your dedicated collections
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid));
    }

    function isEditor() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_editors/$(request.auth.uid));
    }

    function isReporter() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_reporters/$(request.auth.uid));
    }

    function isStaff() {
      return isAdmin() || isEditor();
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      // Allow get for any signed in user (needed for profile fetching)
      allow get: if isSignedIn();
      // Only admins can see the full user list for management
      allow list: if isAdmin(); 
      // Users can only create their own profile matching their Auth UID
      allow create: if isOwner(userId);
      // Updates allowed by owner or admin
      allow update: if isOwner(userId) || isAdmin();
      // Deletion restricted to admins
      allow delete: if isAdmin();

      match /private/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Role verification (Required for the exists() checks above)
    // We allow read to any signed-in user to allow the app to verify roles client-side if needed,
    // but restricted write to admins only.
    match /roles_admins/{userId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_editors/{userId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_reporters/{userId} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    match /pending_news_posts/{newsPostId} {
      // Staff can see all pending posts; Reporters can only see their own drafts
      allow read: if isSignedIn() && (isOwner(resource.data.author_id) || isStaff());
      // Only approved reporters can create new posts
      allow create: if isReporter() && request.resource.data.author_id == request.auth.uid;
      // Updates and deletions restricted to owner or staff
      allow update, delete: if isSignedIn() && (isOwner(resource.data.author_id) || isStaff());
    }

    match /approved_news_posts/{newsPostId} {
      // Publicly readable by all authenticated users
      allow read: if isSignedIn(); 
      // Only editors and admins can manage approved content
      allow create, update, delete: if isStaff();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        // Users can comment on approved news
        allow create: if isSignedIn() && request.resource.data.author_id == request.auth.uid;
        // Users can edit their own comments
        allow update: if isSignedIn() && resource.data.author_id == request.auth.uid;
        // Users can delete their own comments, and admins can moderate them
        allow delete: if isSignedIn() && (resource.data.author_id == request.auth.uid || isAdmin());
      }
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /metadata/{docId} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }
  }
}