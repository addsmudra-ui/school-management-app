rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Master Admin check based on specific email - HIGH PRIORITY
    // This is the SOLE source of truth for admin powers.
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'admin@telugunewspulse.com';
    }

    // Staff check: Master Admin OR authorized role in Firestore
    function isStaff() {
      if (isAdmin()) {
        return true;
      }
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && 
             exists(userPath) && 
             get(userPath).data.role in ['editor', 'Desk Incharge'];
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      // Prevent anyone from creating or assuming an 'admin' role in the DB.
      allow create: if isSignedIn() && request.resource.data.role != 'admin';
      allow get: if request.auth.uid == userId || isStaff();
      allow list: if isStaff();
      // Owners can update themselves but cannot change their role to admin.
      allow update: if (request.auth.uid == userId && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();

      match /private/likes {
        allow read, write: if request.auth.uid == userId || isAdmin();
      }
    }

    match /approved_news_posts/{postId} {
      allow read: if true; 
      allow create: if isStaff();
      allow update: if isStaff() || 
                   (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'commentsCount']));
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || isAdmin());
      }
    }

    match /pending_news_posts/{newsPostId} {
      allow get: if isSignedIn() && (resource.data.author_id == request.auth.uid || isStaff());
      allow list: if isStaff();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.author_id == request.auth.uid || isStaff());
      allow delete: if isSignedIn() && (resource.data.author_id == request.auth.uid || isAdmin());
    }

    match /notifications/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /ads/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /config/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /metadata/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Legacy role tracking collections
    match /roles_admins/{uid} { allow read, write: if isAdmin(); }
    match /roles_editors/{uid} { allow read, write: if isAdmin(); }
    match /roles_reporters/{uid} { allow read, write: if isStaff(); }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}