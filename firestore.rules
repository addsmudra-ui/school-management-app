rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Is the user the Master Admin?
    // We anchor this to the specific email address for absolute security.
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@telugunewspulse.com';
    }

    // Helper: Is the user an Editor or the Admin?
    function isStaff() {
      return isAdmin() || (
        request.auth != null && 
        exists(/databases/$(database)/documents/roles_editors/$(request.auth.uid))
      );
    }

    // 1. Branding & App Config
    match /config/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. User Profiles
    match /users/{userId} {
      // Master Admin can list and read all users.
      // Staff (Editors) can read user list for management.
      // Users can read their own profile.
      allow get: if isAdmin() || isStaff() || (request.auth != null && request.auth.uid == userId);
      allow list: if isAdmin() || isStaff();
      
      // Admin can provision or delete. Users can update their own profile.
      // Note: We prevent users from changing their own role to 'admin'.
      allow create, update: if isAdmin() || (
        request.auth != null && 
        request.auth.uid == userId && 
        request.resource.data.role != 'admin'
      );
      allow delete: if isAdmin();
    }

    // 3. News Posts (Approved)
    match /approved_news_posts/{id} {
      allow read: if true;
      // Only staff (Admin/Editors) can publish or edit live news.
      allow write: if isStaff();
      
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if isStaff() || (request.auth != null && resource.data.userId == request.auth.uid);
      }
    }

    // 4. News Posts (Pending)
    match /pending_news_posts/{id} {
      // Staff can see all pending. Authors can see their own.
      allow read: if isStaff() || (request.auth != null && resource.data.author_id == request.auth.uid);
      // Anyone can submit a post, but they must be themselves.
      allow create: if request.auth != null && request.resource.data.author_id == request.auth.uid;
      // Staff can update/delete (for review). Authors can only update/delete if it's theirs.
      allow update, delete: if isStaff() || (request.auth != null && resource.data.author_id == request.auth.uid);
    }

    // 5. Advertisements
    match /ads/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 6. Notifications
    match /notifications/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 7. Metadata (Locations, Categories)
    match /metadata/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 8. Role assignments (Internal collections)
    match /roles_editors/{id} { allow read, write: if isAdmin(); }
    match /roles_reporters/{id} { allow read, write: if isAdmin(); }
    match /roles_admins/{id} { allow read, write: if isAdmin(); }

    // Fallback: Default to admin-only for any unspecified paths
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}