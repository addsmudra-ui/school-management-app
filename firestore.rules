rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    
    // Checks if the user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the user is the Master Admin (via Email or Admin Collection)
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@telugunewspulse.com' ||
        exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid))
      );
    }

    // Checks if the user is an Editor or Admin
    function isStaff() {
      return isAdmin() || exists(/databases/$(database)/documents/roles_editors/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    // 1. App Configuration (Branding, Settings)
    match /config/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. User Profiles
    match /users/{userId} {
      allow list: if isAdmin();
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create, update: if isAdmin() || (
        isSignedIn() && 
        request.auth.uid == userId && 
        request.resource.data.role != 'admin'
      );
      allow delete: if isAdmin();
    }

    // 3. Approved News Posts (Live Feed)
    match /approved_news_posts/{id} {
      allow read: if true;
      // Admins and Editors can manage live news
      allow write: if isStaff();
      
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
    }

    // 4. Pending News Posts (Drafts/Submissions)
    match /pending_news_posts/{id} {
      // Staff see everything; Reporters see only their own drafts
      allow read: if isStaff() || (isSignedIn() && resource.data.author_id == request.auth.uid);
      
      // Ensures the creator sets themselves as the author
      allow create: if isSignedIn() && request.resource.data.author_id == request.auth.uid;
      
      // Staff can manage all; Reporters manage only their own
      allow update, delete: if isStaff() || (isSignedIn() && resource.data.author_id == request.auth.uid);
    }

    // 5. Ads, Notifications, and Metadata (Locations/Categories)
    match /ads/{id} { allow read: if true; allow write: if isStaff(); }
    match /notifications/{id} { allow read: if true; allow write: if isStaff(); }
    match /metadata/{id} { allow read: if true; allow write: if isStaff(); }

    // 6. Role Management (Internal)
    match /roles_editors/{id} { allow read: if isStaff(); allow write: if isAdmin(); }
    match /roles_reporters/{id} { allow read: if isStaff(); allow write: if isAdmin(); }
    match /roles_admins/{id} { allow read, write: if isAdmin(); }

    // 7. Global Fallback
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}