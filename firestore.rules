rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Role checks based on dedicated marker collections
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid));
    }

    function isReporter() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_reporters/$(request.auth.uid));
    }

    function isStaff() {
      return isAdmin() || exists(/databases/$(database)/documents/roles_editors/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    // User Profiles
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      // Allow creation if owner, update/delete if admin or owner
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
      
      match /private/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Role Markers
    match /roles_admins/{uid} { 
      allow read: if true; 
      allow write: if isAdmin(); 
    }
    match /roles_reporters/{uid} { 
      allow read: if true; 
      allow write: if isAdmin() || isOwner(uid); 
    }
    match /roles_editors/{uid} { 
      allow read: if true; 
      allow write: if isAdmin(); 
    }

    // News Content - PUBLICLY READABLE
    match /approved_news_posts/{newsPostId} {
      allow read: if true; 
      allow create, update, delete: if isStaff();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (resource.data.author_id == request.auth.uid || isStaff());
      }
    }

    match /pending_news_posts/{newsPostId} {
      allow read: if isSignedIn() && (resource.data.author_id == request.auth.uid || isStaff());
      allow create: if isSignedIn() && (isReporter() || isAdmin());
      allow update, delete: if isSignedIn() && (resource.data.author_id == request.auth.uid || isStaff());
    }

    // System Metadata & Config - PUBLIC READ, ADMIN WRITE
    match /notifications/{id} { 
      allow read: if true; 
      allow write: if isStaff(); 
    }
    match /metadata/{id} { 
      allow read: if true; 
      allow write: if isAdmin(); 
    }
    match /config/{id} { 
      allow read: if isAdmin();
      allow write: if isAdmin(); 
    }
  }
}