{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the MandalPulse app.",
      "properties": {
        "id": { "type": "string", "description": "Firebase Auth UID" },
        "phone": { "type": "string", "description": "User's phone number" },
        "name": { "type": "string", "description": "User's full name" },
        "role": { "type": "string", "enum": ["user", "reporter", "admin"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "location": {
          "type": "object",
          "properties": {
            "state": { "type": "string" },
            "district": { "type": "string" },
            "mandal": { "type": "string" }
          }
        }
      },
      "required": ["id", "phone", "role", "name", "status"]
    },
    "NewsPost": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "NewsPost",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "unique_code": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "image_url": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "state": { "type": "string" },
            "district": { "type": "string" },
            "mandal": { "type": "string" }
          }
        },
        "status": { "type": "string" },
        "author_id": { "type": "string" },
        "author_name": { "type": "string" },
        "timestamp": { "type": "string" },
        "likes": { "type": "number" },
        "commentsCount": { "type": "number" }
      },
      "required": ["id", "title", "content", "location", "status", "author_id"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/entities/User" }, "description": "User profiles" },
    "/approved_news_posts/{id}": { "schema": { "$ref": "#/entities/NewsPost" }, "description": "Approved news" },
    "/pending_news_posts/{id}": { "schema": { "$ref": "#/entities/NewsPost" }, "description": "Reporter submissions" },
    "/notifications/{id}": { "schema": { "type": "object" }, "description": "Push notifications history" },
    "/metadata/locations": { "schema": { "type": "object" }, "description": "App location data" },
    "/roles_admins/{uid}": { "schema": { "type": "object" }, "description": "Admin role markers" },
    "/roles_reporters/{uid}": { "schema": { "type": "object" }, "description": "Reporter role markers" }
  }
}