{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user profile within the News Pulse application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "name": {
          "type": "string",
          "description": "The user's display name."
        },
        "phone": {
          "type": "string",
          "description": "The user's phone number."
        },
        "email": {
          "type": "string",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "enum": ["user", "reporter", "editor", "admin"],
          "description": "The assigned role of the user."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected"],
          "description": "The verification status of the user."
        },
        "location": {
          "type": "object",
          "properties": {
            "state": { "type": "string" },
            "district": { "type": "string" },
            "mandal": { "type": "string" }
          }
        },
        "photo": {
          "type": "string",
          "description": "Base64 encoded string or URL of the user's profile photo."
        }
      },
      "required": ["id", "name", "role", "status"]
    },
    "NewsPost": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "NewsPost",
      "type": "object",
      "description": "Represents a news article in the application.",
      "properties": {
        "id": {
          "type": "string"
        },
        "unique_code": {
          "type": "string",
          "description": "5-digit unique code for fact checking."
        },
        "title": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "image_url": {
          "type": "string"
        },
        "video_url": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "location": {
          "type": "object",
          "properties": {
            "state": { "type": "string" },
            "district": { "type": "string" },
            "mandal": { "type": "string" }
          }
        },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected"]
        },
        "visibility": {
          "type": "string",
          "enum": ["live", "hidden"]
        },
        "author_id": {
          "type": "string"
        },
        "author_name": {
          "type": "string"
        },
        "author_role": {
          "type": "string"
        },
        "author_stars": {
          "type": "number"
        },
        "timestamp": {
          "type": "object",
          "description": "Firestore server timestamp."
        },
        "likes": {
          "type": "number"
        },
        "commentsCount": {
          "type": "number"
        }
      },
      "required": ["title", "content", "category", "location", "status", "author_id"]
    },
    "Comment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Comment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "object" }
      },
      "required": ["userName", "text"]
    },
    "Notification": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "target": { "type": "string" },
        "postId": { "type": "string" },
        "timestamp": { "type": "object" }
      },
      "required": ["title", "body", "target"]
    }
  },
  "auth": {
    "providers": ["password", "google", "phone"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Stores user profiles."
        }
      },
      {
        "path": "/approved_news_posts/{newsPostId}",
        "definition": {
          "entityName": "NewsPost",
          "schema": { "$ref": "#/backend/entities/NewsPost" },
          "description": "Publicly viewable approved news posts."
        }
      },
      {
        "path": "/pending_news_posts/{newsPostId}",
        "definition": {
          "entityName": "NewsPost",
          "schema": { "$ref": "#/backend/entities/NewsPost" },
          "description": "News posts awaiting moderation."
        }
      },
      {
        "path": "/approved_news_posts/{newsPostId}/comments/{commentId}",
        "definition": {
          "entityName": "Comment",
          "schema": { "$ref": "#/backend/entities/Comment" },
          "description": "User comments on news posts."
        }
      },
      {
        "path": "/notifications/{id}",
        "definition": {
          "entityName": "Notification",
          "schema": { "$ref": "#/backend/entities/Notification" },
          "description": "Sent notifications history."
        }
      },
      {
        "path": "/ads/{id}",
        "definition": {
          "entityName": "Ad",
          "description": "Hyperlocal advertisements."
        }
      },
      {
        "path": "/config/admin",
        "definition": {
          "entityName": "Config",
          "description": "Application configuration including branding and system status."
        }
      },
      {
        "path": "/metadata/{id}",
        "definition": {
          "entityName": "Metadata",
          "description": "Global metadata like locations and categories."
        }
      }
    ]
  }
}