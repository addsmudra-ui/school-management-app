
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the News Pulse app.",
      "properties": {
        "id": { "type": "string", "description": "Firebase Auth UID" },
        "phone": { "type": "string", "description": "User's phone number" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "name": { "type": "string", "description": "User's full name" },
        "role": { "type": "string", "enum": ["user", "reporter", "admin", "editor"], "description": "Role of the user" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Approval status for reporters" },
        "location": {
          "type": "object",
          "properties": {
            "state": { "type": "string" },
            "district": { "type": "string" },
            "mandal": { "type": "string" }
          }
        },
        "photo": { "type": "string", "description": "Base64 encoded profile photo" }
      },
      "required": ["id", "role", "name", "status"]
    },
    "NewsPost": {
      "title": "NewsPost",
      "type": "object",
      "description": "A news article posted by a reporter or admin.",
      "properties": {
        "id": { "type": "string" },
        "unique_code": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "image_url": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "state": { "type": "string" },
            "district": { "type": "string" },
            "mandal": { "type": "string" }
          }
        },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "author_id": { "type": "string" },
        "author_name": { "type": "string" },
        "timestamp": { "type": "object" },
        "likes": { "type": "number" },
        "commentsCount": { "type": "number" }
      },
      "required": ["id", "title", "content", "location", "status", "author_id"]
    },
    "AdPost": {
      "title": "AdPost",
      "type": "object",
      "description": "A full-screen advertisement story.",
      "properties": {
        "id": { "type": "string" },
        "image_url": { "type": "string" },
        "link": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "state": { "type": "string" },
            "district": { "type": "string" },
            "mandal": { "type": "string" }
          }
        },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "timestamp": { "type": "object" }
      },
      "required": ["id", "image_url", "location", "status"]
    },
    "Comment": {
      "title": "Comment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "object" }
      },
      "required": ["id", "userName", "text"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google.com"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/backend/entities/User" }, "description": "User profiles" },
    "/approved_news_posts/{id}": { "schema": { "$ref": "#/backend/entities/NewsPost" }, "description": "Approved news" },
    "/approved_news_posts/{postId}/comments/{commentId}": { "schema": { "$ref": "#/backend/entities/Comment" }, "description": "Comments on news posts" },
    "/pending_news_posts/{id}": { "schema": { "$ref": "#/backend/entities/NewsPost" }, "description": "Reporter submissions" },
    "/ads/{id}": { "schema": { "$ref": "#/backend/entities/AdPost" }, "description": "Advertisement stories" },
    "/notifications/{id}": { "schema": { "type": "object" }, "description": "Push notifications history" },
    "/metadata/locations": { "schema": { "type": "object" }, "description": "App location data" },
    "/roles_admins/{uid}": { "schema": { "type": "object" }, "description": "Admin role markers" },
    "/roles_reporters/{uid}": { "schema": { "type": "object" }, "description": "Reporter role markers" },
    "/roles_editors/{uid}": { "schema": { "type": "object" }, "description": "Editor role markers" },
    "/config/admin": { "schema": { "type": "object" }, "description": "Admin system configuration" }
  }
}
